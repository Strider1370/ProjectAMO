{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/code_review_graph.py\" session-start",
            "timeout": 10,
            "statusMessage": "Checking Code Review Graph"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/code_review_graph.py\" update",
            "timeout": 30,
            "statusMessage": "Updating Code Review Graph"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/.codex/hooks/code_review_graph.py\" permission-request",
            "timeout": 10,
            "statusMessage": "Checking Code Review Graph approval"
          }
        ]
      }
    ]
  }
}
